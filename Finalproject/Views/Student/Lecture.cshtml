
@{
    ViewBag.Title = "Lecture";
    Layout = "~/Views/Shared/_student.cshtml";
}
<head>
    <style>
        .card {
            box-shadow: 0px 0px 10px 10px rgba(5, 53, 53, .1);
        }
    </style>
</head>

 


<h2 class="text-center">CHOOSE <b style="color: #81B441;">CATEGORIES</b>
                               <img src="~/Content/image/play-button.png" style="height:45px; width:45px;" /></h2>
<div class="row" style="padding:3%">

    @{
        if (ViewBag.vcat != null)
        {
            if (ViewBag.vcat.Rows.Count > 0)
            {
                foreach (var cat in ViewBag.vcat.Rows)
                {



                    <div class="col-sm-2" style="padding:1%">
                        <div class="card" style="">
                                <a href="/student/videos?cid=@cat[0]">
                                    <img src="~/Content/caticons/@cat[2]" class="card-img-top" style="height:140px;">
                                    <div class="card-body">
                                        <p class="card-text text-center text-success">@cat[1]</p>
                                    </div>
                                </a>

                        </div>
                    </div>



                }
            }
            else
            {

                <center>
                    <div class="alert alert-success d-flex align-items-center" role="alert">
                        <svg class="bi flex-shrink-0 me-2" role="img" aria-label="Success:"><use xlink:href="#check-circle-fill" /></svg>
                        <div>
                            No Video Category is added to you by Admin till Now. Please wait...
                        </div>
                    </div>
                </center>
            }
        }
    }
</div>

