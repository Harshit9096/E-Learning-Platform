
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Views/Shared/_student.cshtml";
}


<head>
    <style>

        .a {
            text-align: center;
            margin-top: 50px;
        }
        .form-control {
            width: 420px;
            margin-left: 30px;
        }

        .card {
            height:350px;
            box-shadow: 0px 0px 10px 10px rgba(5, 53, 53, .1), 0px 0px 30px 20px rgb(113, 108, 108,.3);
        }
    </style>
</head>



<h2 class="a">&nbsp;Change<b class="h-color"> Password </b><img src="~/Content/image/login2.png" style="height:45px; width:45px;" /></h2>

<div class="row p-5">

    <div class="col-sm-5">
        <img src="~/Content/image/login4.jpg" style="height:600px;width:550px; margin-left:100px;" />
    </div>
    <div class="col-sm-4 card"  style="margin-top:130px; margin-left:120px; ">
        <div class="card-body">
            <h4 class="card-title text-center" style="color: #81B441">CHANGE PASSWORD</h4>
            <form method="post">
                <div class="form-group mt-3 text-center">
                    <label for="exampleInputEmail1"><b>OLD PASSWORD</b></label>
                    <input type="text" name="opass" class="form-control" aria-describedby="Category" placeholder="Enter old password" />
                </div>
                <div class="form-group mt-3 text-center">
                    <label for="exampleInputEmail1"><b>NEW PASSWORD</b></label>
                    <input type="text" name="npass" class="form-control" aria-describedby="Category" placeholder="Create password" />
                </div>

                <div class="form-group mt-3 text-center">
                    <label for="exampleInputEmail1"><b>CONFIRM PASSWORD</b></label>
                    <input type="text" name="cnpass" class="form-control" aria-describedby="Category" placeholder=" Confirm password" />
                </div>



                <input class="btn btn-success mt-3" type="submit" style="background: #81B441;width:100%;" value="CHANGE NOW" />
            </form>
        </div>
    </div>
</div>

