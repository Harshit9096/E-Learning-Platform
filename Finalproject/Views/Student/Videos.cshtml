
@{
    ViewBag.Title = "Videos";
    Layout = "~/Views/Shared/_student.cshtml";
}


<head>
    <style>
        .card {
            box-shadow: 0px 0px 10px 10px rgba(5, 53, 53, .1);
        }
    </style>
</head>





<h2 class="text-center mb-4">ADDED <b style="color: #81B441;">VIDEO</b>         <img src="~/Content/image/video.png" style="height:45px; width:45px;" /></h2>
<div class="container">
    <div class="row">

        @{
            if (ViewBag.Video != null)
            {
                if (ViewBag.Video.Rows.Count > 0)
                {
                    foreach (var v in ViewBag.Video.Rows)
                    {
                        <div class="col-sm-2"></div>
                        <div class="col-sm-8">

                            <div class="card mb-3" style="">
                                <div class="row g-0">
                                    <div class="col-md-4">
                                        <video height="130px;" controls>
                                            <source src="~/Content/videopic/@v[5]" type="video/ogg" />
                                        </video>
                                    </div>
                                    <div class="col-md-8">
                                        <div class="card-body">
                                            <h5 class="card-title">@v[3]</h5>
                                            <p class="card-text">@v[4]</p>
                                            <p class="card-text"><small class="text-body-secondary">Added on : @v[6]</small></p>
                                        </div>
                                    </div>
                                </div>
                            </div>


                        </div>

                        <div class="col-sm-2"></div>

                    }
                }
            }
        }
    </div>
</div>

