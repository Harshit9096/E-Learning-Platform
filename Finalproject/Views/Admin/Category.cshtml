
@{
    ViewBag.Title = "Category";
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<head>
    <style>

        .card {
            box-shadow: 0px 0px 10px 10px rgba(5, 53, 53, .1), 0px 0px 30px 20px rgb(113, 108, 108,.3);
        }
        .form-control{
            text-decoration:none;
        }
    </style>
</head>

<div class="row p-5">
    <div class="col-sm-4 card">
        <div class="card-body">
            <h4 class="card-title text-center" style="color: #81B441">ADD VIDEO CATEGORY</h4>
            <form method="post" enctype="multipart/form-data">
                <div class="form-group mt-3">
                    <label for="exampleInputEmail1">Category Name</label>
                    <input type="text" name="catname" class="form-control" id="catname" aria-describedby="Category" placeholder="Enter Video Category"  />
                </div>

                <div class="form-group mt-3">
                    <label for="exampleInputEmail1">Category Icon</label>
                    <input type="file" name="caticon" class="form-control" id="caticon" aria-describedby="Category" />
                </div>

                <input class="btn btn-success mt-3" type="submit" style="background: #81B441;width:100%;" value="ADD NOW" />
            </form>
        </div>
    </div>
    <div class="col-sm-7 card text-center ms-5">
        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>S No.</th>
                        <th>Category Name</th>
                        <th>Category Icon</th>
                        <th>Action</th>


                    </tr>
                </thead>
                <tbody>
                    @{
                        foreach (var row in ViewBag.Category.Rows)
                        {
                            <tr>
                                <td>@row[0]</td>
                                <td>@row[1]</td>
                                <td> <img src="~/Content/caticons/@row[2]" style="height:50px; width:50px;" /></td>
                                <td><i class="fa fa-trash text-success"></i></td>

                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>
    </div>

</div>

