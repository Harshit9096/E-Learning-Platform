
@{
    ViewBag.Title = "AddAssignment";
    Layout = "~/Views/Shared/_Admin.cshtml";
}

<head>
    <style>

        .card {
            box-shadow: 0px 0px 10px 10px rgba(5, 53, 53, .1), 0px 0px 30px 20px rgb(113, 108, 108,.3);
        }
    </style>
</head>

<div class="row">
    <div class="col-sm-4  card" style="margin-left:40PX;">
        <div class="card-body">
            <h4 class="card-title text-center" style="color: #81B441">ADD ASSIGMNENT</h4>
            <form method="post" enctype="multipart/form-data">
                <div class="form-group mt-3 text-center">
                    <label for="exampleInputEmail1"><b>CHOOSE BATCHES</b></label>
                    <select class="form-control mt-3" name="cbatch" aria-describedby="Category">
                      <option value="0">Select Batch</option>
                        @foreach (var row in ViewBag.batches.Rows)
            {
                <option value="@row[0]">@row[1]</option>
            }

                    </select>
                </div>


                <div class="form-group mt-3 text-center">
                    <label for="exampleInputEmail1"><b>TITLE</b></label>
                    <input type="text" name="title" class="form-control" id="title" aria-describedby="Category" placeholder="Enter Title" />
                </div>


                <div class="form-group mt-3 text-center">
                    <label for="exampleInputEmail1"><b>DESCRIPTIONS</b></label>
                    <textarea class="form-control" name="desc" aria-describedby="Category" style="height:80px;"></textarea>
                </div>


                <div class="form-group mt-3 text-center">
                    <label for="exampleInputEmail1"><b>CHOOSE TASK </b></label>
                    <input type="file" name ="taskpic" class="form-control" id="taskpic" aria-describedby="Category" />
                </div>

                <div class="form-group mt-3 text-center">
                    <label for="exampleInputEmail1"><b>NAME OF AUTHOR</b></label>
                    <input type="text" name="author" class="form-control" id="author" aria-describedby="Category" placeholder="Enter NAME" />
                </div>


           

                 
                <input class="btn btn-success  mt-4" type="submit" style=" width: 100%; background: #81B441" value="ADD NOW" />

            </form>
        </div>
    </div>


    <div class="col-sm-7  card text-center ms-5">


        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>S No.</th>
                        <th>Batch_Name</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Download_Task</th>
                        <th>Author_name</th>
                        <th>Action</th>



                    </tr>
                </thead>
                <tbody>

                    @{
                        if (ViewBag.task != null) {
                            foreach (var row in ViewBag.task.Rows)
                            {
                            <tr>
                                <td>@row[0]</td>
                                <td>@row[1]</td>
                                <td>@row[2]</td>
                                <td>@row[3]</td>
                              
                              


                                @*<td> <img src="~/Content/taskpic/@row[4]" style="height:50px; width:50px;" /></td>*@

                                <td><a href="~/Content/taskpic/@row[4]" target="_blank" style="text-decoration:none;" ></a><i class="fa fa-download"></i></td>
                                <td>@row[5]</td>
                                <td><i class="fa fa-trash text-success"></i></td>

                            </tr>
                                }
                            }
                        }



                </tbody>
            </table>
        </div>

    </div>
</div>


