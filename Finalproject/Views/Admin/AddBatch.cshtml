
@{
    ViewBag.Title = "AddBatch";
    Layout = "~/Views/Shared/_Admin.cshtml";
}
<head>
    <style>

        .card {
            box-shadow: 0px 0px 10px 10px rgba(5, 53, 53, .1), 0px 0px 30px 20px rgb(113, 108, 108,.3);
        }
    </style>
</head>


<div class="row p-5">
    <div class="col-sm-4 card">
        <div class="card-body">
            <h4 class="card-title text-center" style="color: #81B441">ADD BATCHES</h4>
            <form method="post" enctype="multipart/form-data">
                <div class="form-group mt-3">
                    <label for="exampleInputEmail1"><b>BATCH NAME</b></label>
                    <input type="text" name="Batchname" class="form-control" id="batchname" aria-describedby="Category" placeholder="Enter your batch name" />
                </div>

                <div class="form-group mt-3">
                    <label for="exampleInputEmail1"><b>BATCH START DATE</b></label>
                    <input type="date" name="Batchsdate" class="form-control" id="batchsdate" aria-describedby="Category" placeholder="Enter your batch name" />
                </div>

                <div class="form-group mt-3">
                    <label for="exampleInputEmail1"><b>BATCH END DATE</b></label>
                    <input type="date"  name="Batchedate" class="form-control" id="batchedate" aria-describedby="Category" placeholder="Enter your batch name" />
                </div>
                 
                <div class="form-group mt-3">
                    <label for="exampleInputEmail1"><b>TOTAL FEES</b></label>
                    <input type="text" name="Totalfee" class="form-control" id="totalfee" aria-describedby="Category" placeholder="Enter your batch name" />
                </div>

                <div class="form-group mt-3">
                    <label for="exampleInputEmail1"><b>BATCH TOPIC</b></label>
                    <input type="text" name="Batchtopic" class="form-control" id="batchtopic" aria-describedby="Category" placeholder="Enter your batch name" />
                </div>



                <div class="form-group mt-3">
                    <label for="exampleInputEmail1"><b>BATCH PIC </b></label>
                    <input type="file" name="batchpic" class="form-control" id="batchpic" aria-describedby="Category" />
                </div>

                <input class="btn btn-success mt-4" type="submit" style="background: #81B441; width:100%;" value="ADD NOW" />
            </form>
        </div>
    </div>
    <div class="col-sm-7 card text-center ms-5">
        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>S No.</th>
                        <th>Batch_Name</th>
                        <th>Start_Date</th>
                        <th>End_date</th>
                        <th>Total_fees</th>
                        <th>Batch_Topic</th>
                        <th>Batch_pic</th>
                        <th>Action</th>



                    </tr>
                </thead>
                <tbody>
                    @{
                        foreach (var row in ViewBag.Batch.Rows)
                        {
                                        <tr>
                                            <td>@row[0]</td>
                                            <td>@row[1]</td>
                                            <td>@row[2]</td>
                                            <td>@row[3]</td>
                                            <td>@row[4]</td>
                                            <td>@row[5]</td>


                                            <td> <img src="~/Content/batchpic/@row[6]" style="height:50px; width:50px;" /></td>
                                            <td><i class="fa fa-trash text-success"></i></td>

                                        </tr>
                        }
                    }


                </tbody>
            </table>
        </div>
    </div>

</div>

