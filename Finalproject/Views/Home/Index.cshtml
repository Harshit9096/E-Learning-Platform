
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_General.cshtml";
}
<head>
    <style>
        .root {
            --bgcolor: #262626;
            --txtcolor: linear-gradient( 45deg, #b2ff59, #2e7d32 );
            --tcolor: #b2ff59;
            --hfcolor: #81B441;
        }

        .bg-mycolor {
            background: var(--bgcolor);
        }


        .t-color {
            color: var(--tcolor);
        }

        .h-color {
            color: var(--hfcolor);
        }

        .head-color {
            background: var(--txtcolor);
        }
        .card:hover{
            transform:scale(1.2);
            transition:2s;
        }
    </style>
</head>




<div class="row">
    <!--start slider-->
    <div class="col-sm-12">
        <div id="carouselExample" class="carousel slide carousel-fide" data-bs-ride="carousel">

            <div class="carousel-indicators">
                <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="2" aria-label="Slide 3"></button>
            </div>
            <div class="carousel-inner img mt-2">
                <div class="carousel-item active" data-bs-interval="3000">
                    <img src="~/Content/image/slider.jpeg" alt="..." class="f rounded rounded-3" style="max-height: 700px; background-size: cover; width: 100%;">
                </div>
                <div class="carousel-item" data-bs-interval="3000">
                    <img src="~/Content/image/slider6.jpg" alt="..." class="f rounded rounded-3" style="max-height: 700px;  background-size: cover; width: 100%;">
                </div>
                <div class="carousel-item" data-bs-interval="3000">
                    <img src="~/Content/image/1.jpg" alt="..." class="f rounded rounded-3" style="max-height: 700px;  background-size: cover; width: 100%;">
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </div>
    <!--end slider-->


    <div class="row">
        <div class="col-lg-12 col-sm-12" >
            <div class="h-color fs-1 mt-3" style="text-align:center">BossBerry Learning</div><br />
            <p style="text-align:center;">Vishal Bhattad's CA Foundation Classes is one of the best institute to provide you the complete details of CA Course . Our CA Foundation Online classes are designed by team of <br /> experienced CA(Chartered Accountant) professionals.  We aim to provide the students with an in-depth knowledge and understanding of the concepts related to Chartered Accountancy.<br /> If you have decided to become a chartered accountant, then we are here to help you achieve your goal.</p>



        </div>
    </div> 


    @*start category*@
<div class="row mt-3 mb-5 mt-5">
    <div class="h-color fs-1 mt-3 mb-3" style="text-align:center">COURCES</div><br />

    <div class="col-lg-2 col-md-4 col-sm-6">

        <div class="card ms-4">
            <img src="~/Content/image/batch1.jpeg" class="card-img-top" />
            <div class="card-body text-center">
                <b>C++</b>
            </div>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card ms-2">
            <img src="~/Content/image/Python2.jpeg" class="card-img-top" />
            <div class="card-body text-center">
                <b>Python</b>
            </div>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card ms-2">
            <img src="~/Content/image/download.jpeg" class="card-img-top" />
            <div class="card-body text-center">
                <b>PHP</b>
            </div>
        </div>
    </div>


    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card ms-2">
            <img src="~/Content/image/d1.jpeg" class="card-img-top" />
            <div class="card-body text-center">
                <b>Java</b>
            </div>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card ms-2">
            <img src="~/Content/image/dbms.jpeg" class="card-img-top" />
            <div class="card-body text-center">
                <b>DBMS</b>
            </div>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card ms-2">
            <img src="~/Content/images/slider1.jpg" class="card-img-top" />
            <div class="card-body text-center">
                <b>C++</b>
            </div>
        </div>
    </div>


</div>
</div>

@*end category*@
